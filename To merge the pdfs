from pypdf import PdfWriter
import os
writer = PdfWriter()
files = sorted([file for file in os.listdir() if file.endswith(".pdf")])
for pdf in files:
    writer.append(pdf)
with open("merged-pdf.pdf", "wb") as output_file:
    writer.write(output_file)
print("PDFs merged successfully!")
